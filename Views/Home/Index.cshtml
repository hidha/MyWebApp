@model MyWebApp.Models.TextInputModel
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" id="app">
    <h1>WorkShop - 2</h1>
    <p class="subtitle">Tools to automate manual tasks</p>

    <form method="post">
        <div class="form-group">
            <label for="Content">Text Input</label>
            <textarea id="input"
                      name="input"
                      rows="8"
                      placeholder="Type or paste your text here...">@Model.Content</textarea>
        </div>

        <div class="form-group">
            <label for="SecondContent">Output</label>
            <textarea id="output"
                      name="output"
                      rows="8"
                      placeholder="Type or paste your text here...">@Model.SecondContent</textarea>
        </div>

        <div class="actions">
            <button type="submit">Submit</button>
            <button type="reset" class="secondary" id="clear" v-on:click="onClearClick">Clear</button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.Result))
    {
        <div class="result">
            <h2>Result</h2>
            <p>@Model.Result</p>
        </div>
    }
</div>

<script>
    var app = new Vue({
        el: '#app',
        methods: {
            onClearClick: function() {
                alert('Clear button clicked!');
                $('#input').val('');
                $('#output').val('');
            }
        }
    });
</script>
